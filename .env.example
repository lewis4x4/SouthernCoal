# Copy to .env.local (gitignored). Never commit real keys.
#
# VITE_SUPABASE_ANON_KEY is safe to embed in a production SPA bundle (RLS enforces access).
# Rotate the anon key in the Supabase dashboard if it is ever leaked in a public repo or screenshot.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Field visit — set to "false" to disable Open-Meteo system weather fetch (QA / air-gapped builds).
# VITE_WEATHER_FETCH_ENABLED=false
